---
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar.astro';
import ProfileSection from '@components/ProfileSection.astro';
import AboutSection from '@components/AboutSection.astro';
import ProjectsSection from '@components/ProjectsSection.astro';
import SkillsSection from '@components/SkillsSection.astro';
import FinalSection from '@components/FinalSection.astro';
---

<Layout title="Rahul Kumar — SDET & Test Automation Engineer">
  <div class="w-full max-w-2xl mx-auto px-6 sm:px-8 py-10 sm:py-16 selection:bg-accent/30 selection:text-zinc-900 dark:selection:text-zinc-100">
    <header>
      <Navbar />
      <ProfileSection />
    </header>
    <main>
      <AboutSection />
      <ProjectsSection />
      <SkillsSection />
    </main>
    <footer>
      <FinalSection />
    </footer>
  </div>
</Layout>
