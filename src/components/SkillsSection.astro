---
// Languages
import Javascript from "@assets/icons/javascript.astro";
import Typescript from "@assets/icons/typescript.astro";
import Python from "@assets/icons/python.astro";

// Test Automation
import Playwright from "@assets/icons/playwright.astro";
import Cypress from "@assets/icons/cypress.astro";
import Selenium from "@assets/icons/selenium.astro";
import Webdriverio from "@assets/icons/webdriverio.astro";
import Appium from "@assets/icons/appium.astro";
import Checkly from "@assets/icons/checkly.astro";

// API & Performance Testing
import Postman from "@assets/icons/postman.astro";
import Msw from "@assets/icons/msw.astro";
import K6 from "@assets/icons/k6.astro";
import Jmeter from "@assets/icons/jmeter.astro";

// AI-Assisted Development
import Claude from "@assets/icons/claude.astro";
import Cursor from "@assets/icons/cursor.astro";
import Coderabbit from "@assets/icons/coderabbit.astro";
import Langchain from "@assets/icons/langchain.astro";
import N8n from "@assets/icons/n8n.astro";

// CI/CD & Monitoring
import GithubActions from "@assets/icons/github-actions.astro";
import Vercel from "@assets/icons/vercel.astro";
import Browserstack from "@assets/icons/browserstack.astro";
import Graphite from "@assets/icons/graphite.astro";
import Sentry from "@assets/icons/sentry.astro";
import Git from "@assets/icons/git.astro";
import Docker from "@assets/icons/docker.astro";

// Web Technologies
import Node from "@assets/icons/node.astro";
import React from "@assets/icons/react.astro";
import Nextjs from "@assets/icons/nextjs.astro";
import Express from "@assets/icons/express.astro";

// Databases
import Mongodb from "@assets/icons/mongodb.astro";
import Postgresql from "@assets/icons/postgresql.astro";
import Supabase from "@assets/icons/supabase.astro";

// Project Management
import Linear from "@assets/icons/linear.astro";
import Jira from "@assets/icons/jira.astro";
import Clickup from "@assets/icons/clickup.astro";

// Other (kept from previous design)
import Html from "@assets/icons/html.astro";
import Css from "@assets/icons/css.astro";
import Tailwind from "@assets/icons/tailwind.astro";
import AstroIcon from "@assets/icons/astro.astro";
import MysqlIcon from "@assets/icons/mysql.astro";
import Bash from "@assets/icons/bash.astro";
import Github from "@assets/icons/github.astro";
import Vscode from "@assets/icons/vscode.astro";
import Figma from "@assets/icons/figma.astro";
import Burpsuite from "@assets/icons/burpsuite.astro";

import IconContainer from "@components/IconContainer.astro";

type Skill = { name: string; icon?: any };

const groups: { title: string; items: Skill[] }[] = [
  {
    title: "Languages",
    items: [
      { name: "TypeScript", icon: Typescript },
      { name: "JavaScript", icon: Javascript },
      { name: "Python", icon: Python },
    ],
  },
  {
    title: "Test Automation",
    items: [
      { name: "Playwright", icon: Playwright },
      { name: "Cypress", icon: Cypress },
      { name: "Selenium", icon: Selenium },
      { name: "WebdriverIO", icon: Webdriverio },
      { name: "Appium", icon: Appium },
      { name: "Checkly", icon: Checkly },
    ],
  },
  {
    title: "API & Performance Testing",
    items: [
      { name: "Postman", icon: Postman },
      { name: "MSW", icon: Msw },
      { name: "Grafana k6", icon: K6 },
      { name: "JMeter", icon: Jmeter },
    ],
  },
  {
    title: "AI-Assisted Development",
    items: [
      { name: "Claude Code", icon: Claude },
      { name: "Cursor", icon: Cursor },
      { name: "CodeRabbit", icon: Coderabbit },
      { name: "LangChain", icon: Langchain },
      { name: "n8n", icon: N8n },
    ],
  },
  {
    title: "CI/CD & Monitoring",
    items: [
      { name: "GitHub Actions", icon: GithubActions },
      { name: "Vercel", icon: Vercel },
      { name: "BrowserStack", icon: Browserstack },
      { name: "Graphite", icon: Graphite },
      { name: "Sentry", icon: Sentry },
      { name: "Git", icon: Git },
      { name: "Docker", icon: Docker },
    ],
  },
  {
    title: "Web Technologies",
    items: [
      { name: "Node.js", icon: Node },
      { name: "React", icon: React },
      { name: "Next.js", icon: Nextjs },
      { name: "Express", icon: Express },
    ],
  },
  {
    title: "Databases",
    items: [
      { name: "MongoDB", icon: Mongodb },
      { name: "PostgreSQL", icon: Postgresql },
      { name: "Supabase", icon: Supabase },
    ],
  },
  {
    title: "Project Management & Process",
    items: [
      { name: "Linear", icon: Linear },
      { name: "Jira", icon: Jira },
      { name: "ClickUp", icon: Clickup },
    ],
  },
  {
    title: "Other",
    items: [
      { name: "HTML", icon: Html },
      { name: "CSS", icon: Css },
      { name: "Tailwind", icon: Tailwind },
      { name: "Astro", icon: AstroIcon },
      { name: "MySQL", icon: MysqlIcon },
      { name: "Bash", icon: Bash },
      { name: "GitHub", icon: Github },
      { name: "VSCode", icon: Vscode },
      { name: "Figma", icon: Figma },
      { name: "Burp Suite", icon: Burpsuite },
    ],
  },
];
---

<section class="my-16 sm:my-20 font-sans">
  <div class="flex items-baseline gap-3 mb-6">
    <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Skills</h2>
    <span class="flex-1 h-px bg-zinc-200 dark:bg-zinc-800"></span>
  </div>

  <div class="space-y-7">
    {groups.map(({ title, items }) => (
      <div>
        <h3 class="text-[11px] font-mono uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-3">
          {title}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {items.map(({ name, icon: Icon }) => (
            <IconContainer name={name} hasIcon={!!Icon}>
              {Icon && <Icon size="w-3.5 h-3.5" />}
            </IconContainer>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
