---
import GithubNav from "@assets/icons/github-nav.astro"
import Email from "@assets/icons/email.astro"
import ContainerHover from "@components/ContainerHover.astro"
import ThemeToggle from "@components/ThemeToggle.astro"
---

<nav class="w-full flex justify-between items-center font-sans">
  <a href="/" class="group inline-flex items-center gap-2 text-sm font-medium tracking-tight text-zinc-700 dark:text-zinc-300 hover:text-accent dark:hover:text-accent transition-colors">
    <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 ring-2 ring-emerald-500/20 animate-pulse"></span>
    <span>@mrfullstackdev</span>
  </a>
  <div class="flex gap-1.5 items-center">
    <ThemeToggle />
    <ContainerHover link="mailto:mrfullstackdev@gmail.com" label="Email">
      <Email />
    </ContainerHover>
    <ContainerHover link="https://github.com/mrfullstackdev" label="GitHub">
      <GithubNav />
    </ContainerHover>
  </div>
</nav>
