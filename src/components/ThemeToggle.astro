---
---

<button
  id="theme-toggle"
  class="relative w-9 h-9 rounded-full border border-zinc-200 dark:border-zinc-800 hover:border-accent dark:hover:border-accent transition-all duration-300 flex items-center justify-center group"
  aria-label="Toggle theme"
>
  <svg
    class="w-4 h-4 text-zinc-700 dark:text-zinc-200 transition-transform duration-500 group-active:scale-90"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      class="hidden dark:block"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    />
    <path
      class="block dark:hidden"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    />
  </svg>
</button>

<script>
  const root = document.documentElement;
  const button = document.getElementById('theme-toggle');

  const apply = (dark: boolean) => {
    root.classList.toggle('dark', dark);
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  };

  button?.addEventListener('click', () => {
    const next = !root.classList.contains('dark');

    // @ts-ignore — startViewTransition is progressive enhancement
    if (document.startViewTransition) {
      // @ts-ignore
      document.startViewTransition(() => apply(next));
    } else {
      apply(next);
    }
  });
</script>

<style is:global>
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.4s;
  }
</style>
