---
---

<section class="mt-16 sm:mt-20 mb-16 font-sans">
  <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
    Rahul Kumar
  </h1>
  <p class="mt-3 text-lg sm:text-xl font-serif italic text-zinc-500 dark:text-zinc-400">
    Breaking software so users don't.
  </p>

  <div
    id="hero-terminal"
    class="mt-8 rounded-lg overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-50/60 dark:bg-black/40 backdrop-blur-sm shadow-sm"
  >
    <div class="flex items-center gap-1.5 px-3 py-2 border-b border-zinc-200 dark:border-zinc-800 bg-zinc-100/60 dark:bg-zinc-900/50">
      <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/80"></span>
      <span class="ml-2 text-[11px] font-mono text-zinc-500 dark:text-zinc-500 select-none">
        ~/portfolio — zsh
      </span>
    </div>
    <div class="p-4 sm:p-5 font-mono text-[13px] leading-relaxed">
      <div class="flex items-baseline gap-2" data-line="0">
        <span class="text-emerald-500 select-none">❯</span>
        <span class="text-zinc-700 dark:text-zinc-300" data-type>whoami</span>
        <span class="terminal-caret" data-caret></span>
      </div>
      <p class="mt-1 mb-3 text-zinc-600 dark:text-zinc-400" data-output>
        rahul.kumar &mdash; SDET, building test infrastructure
      </p>

      <div class="flex items-baseline gap-2" data-line="1">
        <span class="text-emerald-500 select-none">❯</span>
        <span class="text-zinc-700 dark:text-zinc-300" data-type>cat ./about.json</span>
        <span class="terminal-caret" data-caret></span>
      </div>
      <pre class="mt-1 mb-3 text-zinc-600 dark:text-zinc-400 whitespace-pre-wrap text-[12.5px]" data-output>{`{
  "role":   "SDET Lead @ SalesMonk.ai",
  "stack":  ["Playwright", "TypeScript", "JS", "Python"],
  "focus":  "E2E · CI/CD · AI-assisted QA",
  "based":  "Gurugram, IN"
}`}</pre>

      <div class="flex items-baseline gap-2" data-line="2">
        <span class="text-emerald-500 select-none">❯</span>
        <span class="terminal-caret terminal-caret--blink"></span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .terminal-caret {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: rgb(63, 63, 70);
    transform: translateY(2px);
  }
  :global(.dark) .terminal-caret {
    background: rgb(228, 228, 231);
  }
  .terminal-caret--blink {
    animation: terminal-blink 1s step-end infinite;
  }
  @keyframes terminal-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  /* Typewriter mode: hide non-active lines via visibility (preserves layout, no CLS) */
  #hero-terminal[data-mode="typing"] [data-line]:not([data-active]),
  #hero-terminal[data-mode="typing"] [data-output]:not([data-revealed]) {
    visibility: hidden;
  }
  #hero-terminal[data-mode="typing"] [data-line] [data-caret] {
    animation: terminal-blink 1s step-end infinite;
  }
  #hero-terminal[data-mode="typing"] [data-line]:not([data-typing]):not([data-done]) [data-caret] {
    display: none;
  }
  #hero-terminal[data-mode="typing"] [data-line][data-done] [data-caret] {
    display: none;
  }
</style>

<script>
  const terminal = document.getElementById('hero-terminal');

  if (terminal) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const lines = Array.from(terminal.querySelectorAll<HTMLElement>('[data-line]'));
    const outputs = Array.from(terminal.querySelectorAll<HTMLElement>('[data-output]'));

    if (!reduced) {
      // Capture original command text, then enable typing mode (which hides everything via CSS)
      const commandTargets = lines.map((line) => line.querySelector<HTMLElement>('[data-type]'));
      const originalTexts = commandTargets.map((el) => el?.textContent?.trim() ?? '');
      commandTargets.forEach((el) => { if (el) el.textContent = ''; });

      terminal.dataset.mode = 'typing';

      const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

      const typeInto = async (el: HTMLElement | null, text: string) => {
        if (!el) return;
        for (const ch of text) {
          el.textContent = (el.textContent ?? '') + ch;
          await sleep(35 + Math.random() * 45);
        }
      };

      const run = async () => {
        await sleep(350);

        for (let i = 0; i < lines.length; i++) {
          const line = lines[i];
          const cmd = originalTexts[i];
          const out = outputs[i];

          line.dataset.active = '';
          line.dataset.typing = '';

          if (cmd) {
            await typeInto(commandTargets[i], cmd);
            await sleep(220);
          }

          delete line.dataset.typing;
          line.dataset.done = '';

          if (out) {
            out.dataset.revealed = '';
            await sleep(450);
          }
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run, { once: true });
      } else {
        run();
      }
    }
  }
</script>
