---
const { name, hasIcon = true } = Astro.props;
---

<span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-[13px] rounded-md border border-zinc-200 dark:border-zinc-800 bg-white/40 dark:bg-zinc-900/40 text-zinc-700 dark:text-zinc-300 hover:border-accent/60 dark:hover:border-accent/60 hover:text-accent dark:hover:text-accent hover:bg-accent/5 transition-all duration-200">
  {hasIcon && (
    <span class="flex items-center justify-center text-zinc-700 dark:text-zinc-300">
      <slot />
    </span>
  )}
  <span class="font-medium tracking-tight">{name}</span>
</span>
